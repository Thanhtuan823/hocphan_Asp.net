@model IEnumerable<lab2.Models.Categories>
@{
    ViewData["Title"] = "Bộ sưu tập cây cảnh";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    // Lấy giả lập 4 sản phẩm nổi bật từ danh mục đầu tiên (hoặc bạn có thể truyền từ Controller)
    var featuredProducts = Model.SelectMany(c => c.Products ?? new List<lab2.Models.Product>()).OrderBy(x => Guid.NewGuid()).Take(4).ToList();
}

<div class="container py-5">
    <div class="row mb-5 align-items-end">
        <div class="col-md-8">
            <h6 class="text-success fw-bold text-uppercase tracking-wider">Khám phá không gian xanh</h6>
            <h2 class="display-4 fw-bold">Nâng tầm phong cách <span class="text-success italic">Sống Trẻ</span></h2>
        </div>
        <div class="col-md-4 text-md-end">
            <p class="text-muted mb-0">Hơn @Model.Sum(x => x.Products?.Count ?? 0) loại cây độc đáo đang chờ bạn</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@item.CategoryId" class="text-decoration-none">
                    <div class="category-banner rounded-5 overflow-hidden position-relative shadow-lg">
                        <div class="banner-bg" style="background-image: url('@(string.IsNullOrEmpty(item.CategoryImageUrl) ? "https://images.unsplash.com/photo-1501004318641-b39e6451bec6?q=80&w=1000" : item.CategoryImageUrl)')"></div>
                        <div class="banner-overlay"></div>

                        <div class="banner-content p-4 d-flex flex-column justify-content-end h-100">
                            <span class="badge bg-white text-success rounded-pill mb-2 w-fit px-3 py-2 shadow-sm fw-bold">
                                @(item.Products?.Count ?? 0) Sản phẩm
                            </span>
                            <h3 class="text-white fw-bold mb-1">@item.CategoryName</h3>
                            <p class="text-white-50 small mb-0 description-text">
                                @(string.IsNullOrEmpty(item.Description) ? "Khám phá ngay bộ sưu tập độc quyền tại TreeDb." : item.Description)
                            </p>

                            <div class="go-icon">
                                <i class="bi bi-arrow-right-short text-white display-4"></i>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <div class="featured-section py-5 px-4 rounded-5 shadow-sm" style="background: #f8faf9;">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-dark">Sản phẩm <span class="text-success">Nổi bật</span></h2>
            <p class="text-muted">Được yêu thích nhất trong tuần qua</p>
        </div>

        <div class="row g-4">
            @if (featuredProducts.Any())
            {
                @foreach (var prod in featuredProducts)
                {
                    <div class="col-6 col-md-3">
                        <div class="card h-100 border-0 bg-transparent product-card-minimal">
                            <div class="position-relative overflow-hidden rounded-4 mb-3 shadow-sm bg-white">
                                <img src="@prod.ImageUrl" class="card-img-top p-2" alt="@prod.ProductName" style="height: 200px; object-fit: contain;">
                                <div class="product-actions">
                                    <button class="btn btn-white shadow-sm rounded-circle p-2"><i class="bi bi-cart-plus text-success"></i></button>
                                </div>
                            </div>
                            <div class="card-body p-0 text-center">
                                <h6 class="fw-bold mb-1">@prod.ProductName</h6>
                                <p class="text-success fw-bold mb-0">@prod.Price.ToString("N0") VNĐ</p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-center text-muted italic small">Đang cập nhật sản phẩm tiêu biểu...</p>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .tracking-wider {
            letter-spacing: 2px;
        }

        .w-fit {
            width: fit-content;
        }

        .italic {
            font-style: italic;
        }

        /* Category Banner Enhancements */
        .category-banner {
            height: 320px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .banner-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            transition: transform 0.6s ease;
        }

        .banner-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.85) 100%);
        }

        .banner-content {
            position: relative;
            z-index: 2;
        }

        .description-text {
            max-height: 0;
            opacity: 0;
            transition: all 0.4s ease;
            overflow: hidden;
        }

        .go-icon {
            position: absolute;
            bottom: 20px;
            right: 20px;
            opacity: 0;
            transform: translateX(-20px);
            transition: all 0.4s ease;
        }

        /* Hover Effects */
        .category-banner:hover {
            transform: translateY(-10px);
        }

            .category-banner:hover .banner-bg {
                transform: scale(1.1);
            }

            .category-banner:hover .description-text {
                max-height: 60px;
                opacity: 1;
                margin-top: 10px;
            }

            .category-banner:hover .go-icon {
                opacity: 1;
                transform: translateX(0);
            }

        /* Product Card Minimal Style */
        .product-card-minimal {
            transition: all 0.3s ease;
        }

            .product-card-minimal:hover {
                transform: translateY(-5px);
            }

        .product-actions {
            position: absolute;
            bottom: 10px;
            right: 10px;
            opacity: 0;
            transform: translateY(10px);
            transition: all 0.3s ease;
        }

        .product-card-minimal:hover .product-actions {
            opacity: 1;
            transform: translateY(0);
        }

        .btn-white {
            background: white;
            border: none;
        }
    </style>
}