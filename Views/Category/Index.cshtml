@model List<lab2.Models.Categories>

<div class="container my-4">
    <h2 class="text-success text-center mb-4">
        📂 Danh sách danh mục
    </h2>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success text-center fw-bold">
            @ViewBag.SuccessMessage
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-success">
                    <tr>
                        <th style="width:80px;">#</th>
                        <th>Tên danh mục</th>
                        <th class="text-center" style="width:150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CategoryId</td>
                            <td>@item.CategoryName</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-primary me-1">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="text-end">
                <a asp-action="Create" class="btn btn-success fw-bold">
                    <i class="bi bi-plus-circle"></i> Thêm danh mục mới
                </a>
            </div>
        </div>
    </div>
</div>