<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Life and Trees</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-light d-flex flex-column min-vh-100">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-user shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Index">
                🌱 Life and Trees
            </a>

            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link text-success" asp-controller="Category" asp-action="Index">Danh mục</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-success" asp-controller="Home" asp-action="Contact">Liên hệ</a>
                </li>
            </ul>

            <!-- GIỎ HÀNG -->
            <a asp-controller="Cart" asp-action="Index"
               class="btn btn-warning fw-bold shadow-sm me-3 position-relative">
                <i class="bi bi-cart3 me-1"></i> Giỏ hàng
                <span id="cart-count"
                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    0
                </span>
            </a>

            <!-- PROFILE -->
            <div class="dropdown">
                <button class="btn btn-outline-success fw-bold dropdown-toggle shadow-sm"
                        type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-person-circle me-1"></i> Hồ sơ
                </button>

                <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                        <span class="dropdown-item-text fw-bold">
                            Xin chào, @User.Identity.Name
                        </span>
                    </li>
                    <li><hr class="dropdown-divider"></li>

                    <li>
                        <a asp-controller="Account" asp-action="Profile" class="dropdown-item">
                            <i class="bi bi-person-lines-fill me-1"></i> Thông tin cá nhân
                        </a>
                    </li>

                    <li>
                        <a asp-controller="Account" asp-action="Settings" class="dropdown-item">
                            <i class="bi bi-cart"></i></i> Quản lý đơn hàng
                        </a>
                    </li>

                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item">
                            <button type="submit" class="btn btn-link text-danger fw-bold p-0">
                                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <div class="container mt-4 mb-5 flex-grow-1">
        @RenderBody()
    </div>

    <!-- FOOTER FULL WIDTH -->
    <footer class="bg-dark text-white pt-4 pb-3 mt-auto w-100">
        <div class="container-fluid px-5">

            <div class="row">
                <!-- LEFT -->
                <div class="col-md-4 mb-3">
                    <h5 class="text-success">🌱 Life and Trees</h5>
                    <p>Chuyên cung cấp cây cảnh, bonsai, cây phong thủy giúp không gian sống xanh hơn.</p>
                </div>

                <!-- CENTER -->
                <div class="col-md-4 mb-3">
                    <h5>Liên kết</h5>
                    <ul class="list-unstyled">
                        <li><a href="/" class="text-white text-decoration-none">Trang chủ</a></li>
                        <li><a href="/Product" class="text-white text-decoration-none">Sản phẩm</a></li>
                        <li><a href="/Cart" class="text-white text-decoration-none">Giỏ hàng</a></li>
                    </ul>
                </div>

                <!-- RIGHT -->
                <div class="col-md-4 mb-3">
                    <h5>Liên hệ</h5>
                    <p>Email: support@lifetrees.com</p>
                    <p>Hotline: 0123 456 789</p>
                </div>
            </div>

            <hr class="border-light" />

            <div class="text-center">
                <p class="mb-0">© 2026 Life and Trees</p>
            </div>

        </div>
    </footer>

    <!-- SCRIPT -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>