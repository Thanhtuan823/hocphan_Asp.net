<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Life and Trees</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light navbar-user shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Index">🌱 Life and Trees</a>
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link text-success" asp-controller="Category" asp-action="Index">Danh mục</a></li>
                <li class="nav-item"><a class="nav-link text-success" asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
            </ul>

            <!-- Giỏ hàng -->
            <a asp-controller="Cart" asp-action="Index"
               class="btn btn-warning fw-bold shadow-sm me-3 position-relative">
                <i class="bi bi-cart3 me-1"></i> Giỏ hàng
                @await Component.InvokeAsync("CartCount")
            </a>
            <!-- Profile dropdown -->
            <div class="dropdown">
                <button class="btn btn-outline-success fw-bold dropdown-toggle shadow-sm" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle me-1"></i> Hồ sơ
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                    <li><span class="dropdown-item-text fw-bold">Xin chào, @User.Identity.Name</span></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a asp-controller="Account" asp-action="Profile" class="dropdown-item"><i class="bi bi-person-lines-fill me-1"></i> Thông tin cá nhân</a></li>
                    <li><a asp-controller="Account" asp-action="Settings" class="dropdown-item"><i class="bi bi-gear me-1"></i> Cài đặt</a></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item">
                            <button type="submit" class="btn btn-link text-danger fw-bold p-0">
                                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>