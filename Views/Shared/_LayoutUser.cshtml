<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Life and Trees</title>

    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user-site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        body {
            font-family: 'Quicksand', sans-serif;
        }

        .nav-link:hover {
            color: #198754 !important;
            transform: translateY(-2px);
            transition: 0.3s;
        }
    </style>
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm bg-white">
        <div class="container">
            <a class="navbar-brand fw-bold text-success fs-3" asp-controller="Home" asp-action="Index">
                🌱 Life and Trees
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#userNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="userNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Category" asp-action="Index">Danh mục</a></li>
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                </ul>

                <div class="d-flex align-items-center gap-3">
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-success rounded-pill px-3 position-relative shadow-sm">
                        <i class="bi bi-cart3"></i>
                        <span class="ms-1 d-none d-md-inline">Giỏ hàng</span>
                        @await Component.InvokeAsync("CartCount")
                    </a>

                    <div class="dropdown">
                        <button class="btn btn-success rounded-pill fw-bold dropdown-toggle shadow-sm px-3" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>
                            <span>@(User.Identity.IsAuthenticated? User.Identity.Name : "Tài khoản")</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="px-3 py-2 bg-light rounded-top">
                                    <small class="text-muted d-block">Xin chào,</small>
                                    <div class="fw-bold text-success">@User.Identity.Name</div>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a asp-controller="Account" asp-action="Profile" class="dropdown-item"><i class="bi bi-person-lines-fill me-2"></i> Hồ sơ của tôi</a></li>
                                <li><a asp-controller="Account" asp-action="Settings" class="dropdown-item"><i class="bi bi-bag-check me-2"></i> Đơn hàng đã mua</a></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a asp-controller="Admin" asp-action="Dashboard" class="dropdown-item text-primary fw-bold"><i class="bi bi-shield-lock me-2"></i> Quản trị hệ thống</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                                        <button type="submit" class="btn btn-link text-danger fw-bold p-0 text-decoration-none w-100 text-start ps-2">
                                            <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Register"><i class="bi bi-pencil-square me-2"></i> Đăng ký</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="container mt-4 mb-5 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white pt-5 pb-3 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h5 class="text-success fw-bold mb-3">🌱 Life and Trees</h5>
                    <p class="text-secondary small">Mang thiên nhiên vào không gian sống của bạn với những loại cây được tuyển chọn kỹ lưỡng.</p>
                </div>
                <div class="col-6 col-lg-4 mb-4 text-lg-center">
                    <h6 class="fw-bold mb-3">Liên kết</h6>
                    <ul class="list-unstyled text-white-50 small">
                        <li><a href="/" class="text-white-50 text-decoration-none">Trang chủ</a></li>
                        <li><a href="/Category" class="text-white-50 text-decoration-none">Sản phẩm</a></li>
                        <li><a href="/Home/Contact" class="text-white-50 text-decoration-none">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-4 mb-4 text-lg-end">
                    <h6 class="fw-bold mb-3">Liên hệ</h6>
                    <p class="text-white-50 small mb-1">Hotline: 0123 456 789</p>
                    <p class="text-white-50 small">Email: support@lifetrees.com</p>
                </div>
            </div>
            <hr class="border-secondary my-3" />
            <div class="text-center text-white-50 small">
                <p class="mb-0">© 2026 Life and Trees. Chúc bạn một ngày xanh mát!</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>