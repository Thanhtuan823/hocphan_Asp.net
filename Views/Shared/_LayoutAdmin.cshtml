<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Life and Trees Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-user shadow-sm">
        <div class="container">
            <!-- Logo dẫn về Dashboard -->
            <a class="navbar-brand fw-bold text-success" asp-controller="Admin" asp-action="Dashboard">
                🌱 Life and Trees - Admin
            </a>

            <!-- Menu điều hướng -->
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link text-success" asp-controller="Admin" asp-action="Dashboard">
                        Admin Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-success" asp-controller="OrderManagement" asp-action="Index">
                        Quản lý đơn hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-success" asp-controller="UserManagement" asp-action="Index">
                        Quản lý tài khoản người dùng
                    </a>
                </li>
            </ul>

            <!-- Profile dropdown -->
            <div class="dropdown">
                <button class="btn btn-outline-success fw-bold dropdown-toggle shadow-sm" type="button"
                        id="adminDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle me-1"></i> Hồ sơ
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminDropdown">
                    <li><span class="dropdown-item-text fw-bold">Xin chào, @User.Identity.Name</span></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a asp-controller="Account" asp-action="Profile" class="dropdown-item">
                            <i class="bi bi-person-lines-fill me-1"></i> Thông tin cá nhân
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Account" asp-action="Settings" class="dropdown-item">
                            <i class="bi bi-gear me-1"></i> Cài đặt
                        </a>
                    </li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item">
                            <button type="submit" class="btn btn-link text-danger fw-bold p-0">
                                <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Nội dung chính: Dashboard hoặc các view quản trị -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>