<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Life and Trees</title>

    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-custom.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Styles", required: false)

    <style>
        body {
            font-family: 'Quicksand', sans-serif;
        }

        .nav-link:hover {
            color: #198754 !important;
            transform: translateY(-2px);
            transition: 0.3s;
        }
    </style>
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm bg-white border-bottom border-success border-3">
        <div class="container">
            <a class="navbar-brand fw-bold text-success fs-3" asp-controller="Admin" asp-action="Dashboard">
                🌱 LIFE & TREES <small class="ms-1 fw-light text-muted" style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1px;">Admin Panel</small>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="adminNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Admin" asp-action="Dashboard">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="OrderManagement" asp-action="Index">Đơn hàng</a></li>
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="UserManagement" asp-action="Index">Người dùng</a></li>
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="ProductManagement" asp-action="Index">Sản phẩm</a></li>
                    <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="CategoryManagement" asp-action="Index">Danh mục</a></li>
                </ul>

                <div class="dropdown">
                    <button class="btn btn-outline-success rounded-pill fw-bold dropdown-toggle shadow-sm px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-shield-lock-fill me-1"></i> Quản trị viên
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                        <li class="px-3 py-2 bg-light rounded-top text-center">
                            <small class="text-muted d-block">Admin Account</small>
                            <div class="fw-bold text-success">@User.Identity.Name</div>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a asp-controller="Account" asp-action="Profile" class="dropdown-item"><i class="bi bi-person-badge me-2"></i> Hồ sơ cá nhân</a></li>
                        <li><a asp-controller="Home" asp-action="Index" class="dropdown-item"><i class="bi bi-eye me-2"></i> Xem trang chủ</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                                <button type="submit" class="btn btn-link text-danger fw-bold p-0 text-decoration-none w-100 text-start ps-2">
                                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <main class="container my-5 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-white border-top py-4 mt-auto">
        <div class="container text-center text-muted">
            <small>&copy; 2026 - <strong>Life and Trees</strong> Management System | Internal Use Only</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>