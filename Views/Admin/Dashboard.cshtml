@model lab2.Models.AdminDashboard
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">📊 Tổng quan hệ thống</h2>
            <p class="text-muted">Cập nhật số liệu mới nhất về cửa hàng của bạn</p>
        </div>
        <button class="btn btn-success rounded-pill px-4"><i class="bi bi-download me-2"></i>Xuất báo cáo</button>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card stat-card shadow-sm h-100 p-3">
                <div class="card-body">
                    <div class="icon-box bg-soft-primary">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Người dùng</h6>
                    <h3 class="fw-bold mb-0">@Model.TotalUsers.ToString("N0")</h3>
                    <small class="text-success"><i class="bi bi-arrow-up"></i> 12% tháng này</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card stat-card shadow-sm h-100 p-3">
                <div class="card-body">
                    <div class="icon-box bg-soft-success">
                        <i class="bi bi-cart-check-fill"></i>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Đơn hàng</h6>
                    <h3 class="fw-bold mb-0">@Model.TotalOrders.ToString("N0")</h3>
                    <small class="text-success"><i class="bi bi-arrow-up"></i> 5% hôm nay</small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card stat-card shadow-sm h-100 p-3">
                <div class="card-body">
                    <div class="icon-box bg-soft-warning">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <h6 class="text-muted text-uppercase small fw-bold">Doanh thu</h6>
                    <h3 class="fw-bold mb-0 text-success">@Model.TotalRevenue.ToString("N0") <small class="fs-6">đ</small></h3>
                    <small class="text-muted">Dựa trên thanh toán thực tế</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="chart-container">
                <h5 class="fw-bold mb-4">📈 Biểu đồ tăng trưởng</h5>
                <canvas id="adminChart" style="max-height: 400px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('adminChart').getContext('2d');

        // Tạo gradient cho biểu đồ
        const gradient = ctx.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(25, 135, 84, 0.4)');
        gradient.addColorStop(1, 'rgba(25, 135, 84, 0)');

        const adminChart = new Chart(ctx, {
            type: 'line', // Đổi sang Line chart nhìn sẽ sang hơn
            data: {
                labels: ['Người dùng', 'Đơn hàng', 'Doanh thu (mười nghìn)'],
                datasets: [{
                    label: 'Giá trị thực tế',
                    data: [@Model.TotalUsers, @Model.TotalOrders, @Model.TotalRevenue / 10000], // Giả lập scale doanh thu để chart đẹp hơn
                    fill: true,
                    backgroundColor: gradient,
                    borderColor: '#198754',
                    borderWidth: 3,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#198754',
                    pointRadius: 5,
                    tension: 0.4 // Làm mượt đường kẻ
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { display: false }
                    },
                    x: {
                        grid: { display: false }
                    }
                }
            }
        });
    </script>
}