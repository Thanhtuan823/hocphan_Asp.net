@model lab2.Models.AdminDashboard
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">📊 Hệ thống Quản trị</h2>

        <div class="d-flex gap-2 align-items-end bg-white p-2 rounded-3 shadow-sm border">
            <div>
                <label class="small fw-bold text-muted d-block">Từ ngày</label>
                <input type="date" id="startDate" class="form-control form-control-sm border-0">
            </div>
            <div class="border-start ps-2">
                <label class="small fw-bold text-muted d-block">Đến ngày</label>
                <input type="date" id="endDate" class="form-control form-control-sm border-0">
            </div>
            <button onclick="applyFilter()" class="btn btn-success btn-sm px-3 rounded-pill shadow-sm">
                <i class="bi bi-filter"></i> Lọc
            </button>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card stat-card shadow-sm border-0 border-start border-success border-4">
                <div class="card-body">
                    <h6 class="text-muted small fw-bold">DOANH THU</h6>
                    <h3 class="fw-bold text-success mb-0" id="displayRevenue">
                        @Model.TotalRevenue.ToString("N0") <small class="fs-6">đ</small>
                    </h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card shadow-sm border-0 border-start border-primary border-4">
                <div class="card-body">
                    <h6 class="text-muted small fw-bold">TỔNG ĐƠN HÀNG</h6>
                    <h3 class="fw-bold text-primary mb-0" id="displayOrders">@Model.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card shadow-sm border-0 border-start border-info border-4">
                <div class="card-body">
                    <h6 class="text-muted small fw-bold">KHÁCH HÀNG</h6>
                    <h3 class="fw-bold text-info mb-0">@Model.TotalUsers</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h5 class="fw-bold mb-4">Xu hướng Doanh thu thực tế</h5>
                <div style="height: 300px;"><canvas id="mainChart"></canvas></div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 rounded-4 h-100">
                <h5 class="fw-bold mb-4">Tỉ lệ Đơn hàng</h5>
                <div style="height: 300px;"><canvas id="pieChart"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const rawData = @Html.Raw(Model.RawOrdersJson);
        let mainChart, pieChart;

        function renderDashboard(data) {
            const ctxLine = document.getElementById('mainChart').getContext('2d');
            const ctxPie = document.getElementById('pieChart').getContext('2d');

            if (mainChart) mainChart.destroy();
            if (pieChart) pieChart.destroy();

            // 1. Logic Biểu đồ đường (Chỉ tính doanh thu từ đơn SUCCESS)
            const revMap = {};
            data.filter(o => o.Status === "Success").forEach(o => {
                revMap[o.Date] = (revMap[o.Date] || 0) + o.Amount;
            });

            const labels = Object.keys(revMap).sort();
            mainChart = new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu',
                        data: labels.map(l => revMap[l]),
                        borderColor: '#198754',
                        backgroundColor: 'rgba(25, 135, 84, 0.1)',
                        fill: true, tension: 0.4
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });

            // 2. Logic Biểu đồ tròn (Tỉ lệ trạng thái)
            const s = data.filter(o => o.Status === "Success").length;
            const p = data.filter(o => ["Pending", "Shipping", "CancelRequested"].includes(o.Status)).length;
            const c = data.filter(o => o.Status === "Cancelled").length;

            pieChart = new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ['Thành công', 'Đang xử lý', 'Đã hủy'],
                    datasets: [{
                        data: [s, p, c],
                        backgroundColor: ['#198754', '#ffc107', '#dc3545'],
                        borderWidth: 0
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, cutout: '70%' }
            });

            // 3. Cập nhật các con số Card
            const totalRev = data.filter(o => o.Status === "Success").reduce((acc, curr) => acc + curr.Amount, 0);
            document.getElementById('displayRevenue').innerHTML = totalRev.toLocaleString() + " <small class='fs-6'>đ</small>";
            document.getElementById('displayOrders').innerText = data.length;
        }

        function applyFilter() {
            const start = document.getElementById('startDate').value;
            const end = document.getElementById('endDate').value;

            const filtered = rawData.filter(o => {
                if (!start && !end) return true;
                return (!start || o.Date >= start) && (!end || o.Date <= end);
            });

            renderDashboard(filtered);
        }
        // Khởi động
        renderDashboard(rawData);
    </script>
}