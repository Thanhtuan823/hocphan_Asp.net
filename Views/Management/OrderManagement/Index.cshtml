@model IEnumerable<lab2.Models.Order>

<div class="container mt-4">
    <h2 class="text-success fw-bold mb-3">Quản lý đơn hàng</h2>
    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-success">
            <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Địa chỉ</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.OrderId</td>
                    <td>@order.Name</td>
                    <td>@order.Address1, @order.City</td>
                    <td>@order.OrderPlaced.ToString("dd/MM/yyyy")</td>
                    <td>@order.TotalAmount.ToString("C")</td>
                    <td>@order.Status</td>
                    <td>
                        <!-- Xem chi tiết -->
                        <a asp-action="Details" asp-route-id="@order.OrderId"
                           class="btn btn-outline-primary btn-sm">Chi tiết</a>

                        <!-- Cập nhật trạng thái -->
                        <form asp-action="UpdateStatus" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@order.OrderId" />
                            <select name="status" class="form-select form-select-sm d-inline w-auto me-2">
                                <option value="Pending" selected="@("Pending" == order.Status)">Chờ xử lý</option>
                                <option value="Shipping" selected="@("Shipping" == order.Status)">Đang giao</option>
                                <option value="Completed" selected="@("Completed" == order.Status)">Hoàn tất</option>
                            </select>
                            <button type="submit" class="btn btn-outline-success btn-sm">Cập nhật</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>