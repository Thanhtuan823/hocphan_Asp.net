@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "Xóa người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <h2 class="text-danger fw-bold mb-3">⚠️ Xóa người dùng</h2>
    <p>Bạn có chắc chắn muốn xóa tài khoản <strong>@Model.UserName</strong> không?</p>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>