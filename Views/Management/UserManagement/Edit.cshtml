@model lab2.Models.UserProfileViewModel
@{
    ViewData["Title"] = "Admin - Chỉnh sửa hồ sơ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .profile-wrapper {
        background: #f4f7f6;
        min-height: 100vh;
    }

    .main-profile-card {
        border-radius: 25px;
        overflow: hidden;
        border: none;
        background: #fff;
    }

    .profile-sidebar {
        background: linear-gradient(180deg, #198754 0%, #0d4d30 100%);
    }

    .form-control-custom {
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
        padding: 12px 15px;
        border-radius: 12px;
        width: 100%;
        transition: all 0.3s;
    }

        .form-control-custom:focus {
            border-color: #198754;
            background-color: #fff;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
            outline: none;
        }

    .form-label-custom {
        font-weight: 600;
        color: #495057;
        margin-bottom: 5px;
    }
</style>

<div class="profile-wrapper py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11 col-xl-10">
                <div class="main-profile-card shadow-lg animate__animated animate__zoomIn">
                    <form id="profileForm" asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        @* Quan trọng: Giữ ID của User cần sửa *@
                        <input type="hidden" asp-for="User.Id" />
                        <input type="hidden" asp-for="OrderAddress.UserId" />

                        <div class="row g-0">
                            <div class="col-md-4 profile-sidebar text-white text-center p-5">
                                <div class="avatar-container mb-4">
                                    <img src="https://ui-avatars.com/api/?name=@Model.User.UserName&background=fff&color=198754&size=150" class="rounded-circle shadow-lg border border-4 border-white-50">
                                </div>
                                <h3 class="fw-bold mb-1">@Model.User.UserName</h3>
                                <p class="small opacity-75">Hồ sơ người dùng</p>
                            </div>

                            <div class="col-md-8 p-4 p-md-5 bg-white">
                                <h5 class="fw-bold text-success mb-4"><i class="bi bi-person-badge me-2"></i>THÔNG TIN CƠ BẢN</h5>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label-custom small">Tên tài khoản</label>
                                        <input asp-for="User.UserName" class="form-control-custom">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom small">Email</label>
                                        <input asp-for="User.Email" class="form-control-custom" required>
                                    </div>
                                </div>

                                <h5 class="fw-bold text-success mb-4 mt-5"><i class="bi bi-truck me-2"></i>ĐỊA CHỈ & LIÊN HỆ</h5>

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label-custom small">Người nhận hàng</label>
                                        <input asp-for="OrderAddress.Name" class="form-control-custom">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom small">Số điện thoại</label>
                                        <input asp-for="OrderAddress.PhoneNumber" class="form-control-custom">
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label-custom small">Địa chỉ chi tiết</label>
                                    <input asp-for="OrderAddress.Address1" class="form-control-custom">
                                </div>

                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label-custom small">Thành phố</label>
                                        <input asp-for="OrderAddress.City" class="form-control-custom">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label-custom small">Mã Zip</label>
                                        <input asp-for="OrderAddress.Zip" class="form-control-custom">
                                    </div>
                                </div>

                                <div class="d-flex gap-2 justify-content-end mt-5">
                                    <a asp-controller="UserManagement" asp-action="Index" class="btn btn-light px-4 rounded-pill border">Hủy bỏ</a>
                                    <button type="submit" class="btn btn-success px-5 rounded-pill shadow-sm fw-bold">LƯU THAY ĐỔI</button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function () {
        $('#profileForm').on('submit', function (e) {
            e.preventDefault();
            var form = $(this);
            $.post(form.attr('action'), form.serialize(), function (res) {
                if (res.success) {
                    Swal.fire({ icon: 'success', title: 'Thành công!', text: res.message, timer: 1500, showConfirmButton: false })
                    .then(() => { window.location.href = '@Url.Action("Index", "UserManagement")'; });
                } else {
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: res.message });
                }
            });
        });
    });
</script>