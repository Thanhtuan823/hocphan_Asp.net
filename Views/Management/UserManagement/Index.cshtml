@model IEnumerable<lab2.Models.UserWithRoles>
@{
    ViewData["Title"] = "Quản lý tài khoản người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container mt-4">
    <h2 class="text-success fw-bold mb-3">👤 Quản lý tài khoản người dùng</h2>
    <p class="text-muted">Danh sách người dùng trong hệ thống.</p>

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-success">
            <tr>
                <th>Tên đăng nhập</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@string.Join(", ", user.Roles)</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-outline-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>