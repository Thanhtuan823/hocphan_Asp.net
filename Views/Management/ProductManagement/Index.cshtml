@model IEnumerable<lab2.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <style>
        .animate-fade {
            animation: fadeIn 0.4s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        input[type=number] {
            -moz-appearance: textfield;
        }

        .product-table-card {
            border-radius: 15px;
            border: none;
            overflow: hidden;
        }

        .img-preview-table {
            width: 52px;
            height: 52px;
            object-fit: cover;
            border-radius: 10px;
            border: 1px solid #eee;
        }

        .price-text {
            color: #d9534f;
            font-weight: 700;
        }

        .custom-focus:focus {
            background-color: #ffffff !important;
            border-color: #198754 !important;
            box-shadow: 0 0 0 4px rgba(25, 135, 84, 0.1) !important;
        }

        #imgPreviewBox {
            width: 100%;
            height: 160px;
            border: 2px dashed #cbd5e1;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f8fafc;
            overflow: hidden;
            transition: 0.3s;
        }

            #imgPreviewBox img {
                max-height: 100%;
                max-width: 100%;
                object-fit: contain;
            }
    </style>
}

<div class="container py-4 animate-fade">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="fw-bold mb-0 text-dark"><i class="bi bi-box-seam text-success me-2"></i>Kho Sản Phẩm</h2>
            <p class="text-muted small mb-0">Hệ thống có <span class="badge bg-success-subtle text-success border">@Model.Count()</span> mặt hàng</p>
        </div>
        <div class="col-md-6 text-md-end">
            <button type="button" class="btn btn-success fw-bold rounded-3 px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#quickAddProductModal">
                <i class="bi bi-plus-lg me-1"></i> Thêm mới nhanh
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card product-table-card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá bán</th>
                        <th>Tồn kho</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl" class="img-preview-table me-3 shadow-sm" onerror="this.src='/images/default.png'">
                                    <div>
                                        <div class="fw-bold text-dark">@item.ProductName</div>
                                        <div class="text-muted" style="font-size: 0.7rem;">ID: #@item.ProductId</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-white text-dark border fw-normal">@item.Category?.CategoryName</span></td>
                            <td><span class="price-text">@item.Price.ToString("N0") đ</span></td>
                            <td>
                                <span class="badge @(item.Quantity > 5 ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger") px-2">
                                    @item.Quantity cây
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="btn-group border rounded-2">
                                    <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-white btn-sm px-3 border-end">
                                        <i class="bi bi-pencil text-primary"></i>
                                    </a>
                                    <button type="button" class="btn btn-white btn-sm px-3" onclick="showDeleteModal(@item.ProductId, '@item.ProductName')">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modal Thêm Nhanh (Create) *@
<div class="modal fade" id="quickAddProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-success"><i class="bi bi-magic me-2"></i>Tạo sản phẩm mới</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <form asp-action="Create" method="post">
                    <div class="row g-3">
                        <div class="col-md-7">
                            <label class="form-label small fw-bold text-muted">TÊN SẢN PHẨM</label>
                            <input name="ProductName" class="form-control border-2 bg-light shadow-none py-2 rounded-3 custom-focus"
                                   placeholder="Ví dụ: Cây Lưỡi Hổ Thái..." required />
                        </div>

                        <div class="col-md-5">
                            <label class="form-label small fw-bold text-muted">DANH MỤC</label>
                            <select name="CategoryId" class="form-select border-2 bg-light shadow-none py-2 rounded-3 custom-focus" asp-items="ViewBag.CategoryId" required>
                                <option value="">-- Chọn nhóm cây --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">GIÁ BÁN (VNĐ)</label>
                            <div class="input-group">
                                <input type="number" name="Price" class="form-control border-2 bg-light shadow-none py-2 rounded-start-3 custom-focus border-end-0"
                                       placeholder="Ví dụ: 125000" required />
                                <span class="input-group-text border-2 bg-light border-start-0 rounded-end-3 text-muted">đ</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted">SỐ LƯỢNG NHẬP</label>
                            <div class="input-group">
                                <input type="number" name="Quantity" class="form-control border-2 bg-light shadow-none py-2 rounded-start-3 custom-focus border-end-0"
                                       placeholder="50" required />
                                <span class="input-group-text border-2 bg-light border-start-0 rounded-end-3 text-muted">Cây</span>
                            </div>
                        </div>

                        <div class="col-md-7">
                            <label class="form-label small fw-bold text-muted">ĐƯỜNG DẪN ẢNH (URL)</label>
                            <input id="imgUrlInput" name="ImageUrl" class="form-control border-2 bg-light shadow-none py-2 rounded-3 custom-focus mb-2"
                                   placeholder="https://..." oninput="handlePreview(this.value)" />
                        </div>

                        <div class="col-md-5 text-center">
                            <label class="form-label small fw-bold text-muted">XEM TRƯỚC ẢNH</label>
                            <div id="imgPreviewBox">
                                <div class="text-center text-muted">
                                    <i class="bi bi-image fs-1 d-block"></i>
                                    <span style="font-size: 0.7rem;">Chưa có ảnh</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted">MÔ TẢ SẢN PHẨM</label>
                            <textarea name="Description" class="form-control border-2 bg-light shadow-none py-2 rounded-3 custom-focus"
                                      rows="3" placeholder="Mô tả ngắn về cây..."></textarea>
                        </div>
                    </div>

                    <div class="row g-2 mt-4">
                        <div class="col-4">
                            <button type="button" class="btn btn-outline-secondary w-100 fw-bold py-2 rounded-3" data-bs-dismiss="modal">HỦY BỎ</button>
                        </div>
                        <div class="col-8">
                            <button type="submit" class="btn btn-success w-100 fw-bold py-2 rounded-3 shadow-sm">
                                <i class="bi bi-check2-circle me-1"></i> XÁC NHẬN LƯU KHO
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* Modal Xóa *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="p-4 text-center">
                <div class="mb-3 text-danger"><i class="bi bi-trash3" style="font-size: 3.5rem;"></i></div>
                <h4 class="fw-bold">Bạn chắc chắn muốn xóa?</h4>
                <p class="text-muted mb-4 small">Hành động này sẽ xóa vĩnh viễn <strong id="delProductName" class="text-dark"></strong>.</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light px-4 rounded-3 fw-bold" data-bs-dismiss="modal">GIỮ LẠI</button>
                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" name="id" id="delProductId" />
                        <button type="submit" class="btn btn-danger px-4 rounded-3 fw-bold shadow-sm">XÓA NGAY</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showDeleteModal(id, name) {
            document.getElementById('delProductId').value = id;
            document.getElementById('delProductName').innerText = name;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        function handlePreview(url) {
            const previewBox = document.getElementById('imgPreviewBox');
            if (url.trim() !== "") {
                previewBox.innerHTML = `<img src="${url}" onerror="this.onerror=null; this.parentNode.innerHTML='<span class=\'text-danger small p-2 text-center\'>Link ảnh lỗi</span>';">`;
            } else {
                previewBox.innerHTML = `<div class="text-center text-muted"><i class="bi bi-image fs-1 d-block"></i><span style="font-size: 0.7rem;">Chưa có ảnh</span></div>`;
            }
        }
    </script>
}