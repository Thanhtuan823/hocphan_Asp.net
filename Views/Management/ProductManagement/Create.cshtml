@model lab2.Models.Product


<div class="chat-box">
    <h2>Thêm sản phẩm mới</h2>
 @using (Html.BeginForm("Create", "Product", FormMethod.Post))
 {
     <!-- Hiển thị lỗi chung -->
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="row">
            <!-- Cột trái -->
            <div class="col-md-6">
                <div class="form-group">
                    @Html.LabelFor(m => m.ProductName, "Tên sản phẩm", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.ProductName, new { @class = "form-control", placeholder = "Nhập tên sản phẩm" })
                    @Html.ValidationMessageFor(m => m.ProductName, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Description, "Mô tả", new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.Description, new { @class = "form-control", placeholder = "Nhập mô tả", rows = 3 })
                    @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Price, "Giá", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Price, new { @class = "form-control", placeholder = "Nhập giá" })
                    @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
                </div>
            </div>

            <!-- Cột phải -->
            <div class="col-md-6">
                <div class="form-group">
                    @Html.LabelFor(m => m.Quantity, "Số lượng", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Quantity, new { @class = "form-control", placeholder = "Nhập số lượng" })
                    @Html.ValidationMessageFor(m => m.Quantity, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.ImageUrl, "Hình ảnh (URL)", new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.ImageUrl, new { @class = "form-control", placeholder = "Nhập URL hình ảnh" })
                    @Html.ValidationMessageFor(m => m.ImageUrl, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.CategoryId, "Danh mục", new { @class = "form-label" })
                    @Html.DropDownListFor(m => m.CategoryId, (SelectList)ViewBag.Category, "-- Chọn danh mục --", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.CategoryId, "", new { @class = "text-danger" })
                </div>
            </div>
        </div>
            <button type="submit" class="btn btn-success mt-3">Thêm sản phẩm</button>  
 }


</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
