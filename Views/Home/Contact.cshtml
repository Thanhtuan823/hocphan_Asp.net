@{
    ViewData["Title"] = "Liên hệ";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-success mb-3">
            <i class="bi bi-headset"></i> Liên hệ với chúng tôi
        </h1>
        <p class="text-muted">Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn. Hãy để lại lời nhắn nhé!</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow rounded-4 border-0 h-100">
                <div class="card-body p-4 p-md-5">
                    <h4 class="mb-4 text-success fw-bold">Gửi tin nhắn cho LifeTrees</h4>

                    @* Hiển thị thông báo khi gửi thành công *@
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @* Thêm asp-action và method post *@
                    <form asp-action="Contact" method="post">
                        <div class="form-floating mb-3">
                            <input type="text" name="name" class="form-control rounded-3" id="inputName" placeholder="Nhập tên của bạn" required />
                            <label for="inputName">Họ và tên</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input type="email" name="email" class="form-control rounded-3" id="inputEmail" placeholder="example@gmail.com" required />
                            <label for="inputEmail">Địa chỉ Email</label>
                        </div>

                        <div class="form-floating mb-4">
                            <textarea name="message" class="form-control rounded-3" id="inputMessage" placeholder="Nhập nội dung..." style="height: 150px" required></textarea>
                            <label for="inputMessage">Nội dung tin nhắn...</label>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-3 fw-bold shadow-sm">
                            <i class="bi bi-send me-2"></i> Gửi thông tin
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow rounded-4 border-0 bg-success text-white h-100">
                <div class="card-body p-4 p-md-5">
                    <h4 class="fw-bold mb-4">Thông tin liên hệ</h4>
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-white text-success rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px; flex-shrink: 0;">
                            <i class="bi bi-geo-alt fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Địa chỉ</h6>
                            <p class="mb-0 text-white-50">Việt Nam</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-white text-success rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px; flex-shrink: 0;">
                            <i class="bi bi-envelope fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Email</h6>
                            <p class="mb-0 text-white-50">thanhnguyen10988@gmail.com</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-white text-success rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px; flex-shrink: 0;">
                            <i class="bi bi-telephone fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Hotline</h6>
                            <p class="mb-0 text-white-50">0123 456 789</p>
                        </div>
                    </div>

                    <hr class="border-white opacity-50 my-4" />

                    <h6 class="fw-bold mb-2"><i class="bi bi-clock me-2"></i>Giờ làm việc</h6>
                    <p class="mb-0 text-white-50">Thứ 2 - Chủ nhật: 8:00 - 21:00</p>
                </div>
            </div>
        </div>
    </div>
</div>