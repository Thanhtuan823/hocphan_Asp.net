@model IEnumerable<lab2.Models.Product>

@{
    ViewData["Title"] = "Trang chủ - Life and Trees";

    // XỬ LÝ LOGIC LỌC SẢN PHẨM TẠI ĐÂY
    // 1. Mới nhất: Lấy 4 sản phẩm có ID lớn nhất (vừa được thêm vào DB)
    var newestProducts = Model.OrderByDescending(x => x.ProductId).Take(4);

    // 2. Bán chạy: Lấy 8 sản phẩm có số lượng bán (SoldQuantity) cao nhất
    var bestSellingProducts = Model.OrderByDescending(x => x.SoldQuantity).Take(8);
}

@section Styles {
    <style>
        :root {
            --primary-green: #2e7d32;
            --light-green: #e8f5e9;
            --dark-green: #1b5e20;
            --accent-orange: #ff9800;
        }

        /* 1. Hero Section */
        .hero-banner {
            height: 80vh;
            background: linear-gradient(to bottom, rgba(27, 94, 32, 0.4), rgba(0, 0, 0, 0.6)), url('https://images.pexels.com/photos/36679737/pexels-photo-36679737.jpeg');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0 0 40px 40px;
            color: white;
            text-align: center;
            margin-top: -16px;
        }

        @@media (min-width: 992px) {
            .hero-banner {
                background-attachment: fixed;
            }
        }

        .hero-text h1 {
            font-size: clamp(2.5rem, 8vw, 4.5rem);
            font-weight: 900;
            letter-spacing: 4px;
            text-shadow: 2px 4px 10px rgba(0,0,0,0.5);
            margin-bottom: 1.2rem;
        }

        .hero-text p {
            font-size: 1.1rem;
            font-weight: 300;
            max-width: 600px;
            margin: 0 auto 2.5rem;
            color: #f8f9fa;
        }

        .btn-custom-primary {
            background-color: var(--primary-green);
            color: white;
            transition: all 0.3s ease;
        }

            .btn-custom-primary:hover {
                background-color: var(--dark-green);
                color: white;
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(46, 125, 50, 0.3);
            }

        /* 2. Features Section */
        .feature-box {
            padding: 1.5rem;
            transition: transform 0.3s ease;
        }

            .feature-box:hover {
                transform: translateY(-5px);
            }

        .icon-wrapper {
            width: 70px;
            height: 70px;
            background-color: var(--light-green);
            color: var(--primary-green);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 1.2rem auto;
        }

        @@media (min-width: 768px) {
            .border-md-x {
                border-left: 1px solid #eee;
                border-right: 1px solid #eee;
            }
        }

        /* 2.5 Care Process Section */
        .care-process-section {
            background-color: var(--light-green);
            border-radius: 40px;
            position: relative;
            overflow: hidden;
        }

            .care-process-section::before {
                content: '';
                position: absolute;
                top: 0;
                right: 0;
                bottom: 0;
                left: 0;
                background-image: url('data:image/svg+xml,%3Csvg width="100" height="100" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"%3E%3Cpath d="M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43 7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm28-65c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm23 19c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-6 46c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm33 31c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM46 4c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm15 30c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm-9 60c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm31-20c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zM14 6c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zM11 50c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm71-2c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm-18 24c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm-41-4c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zM93 11c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm-4 62c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm-32-60c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm-36 1c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm24 82c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zM21 21c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1zm66 66c.552 0 1-.448 1-1s-.448-1-1-1-1 .448-1 1 .448 1 1 1z" fill="%232e7d32" fill-opacity="0.03" fill-rule="evenodd"/%3E%3C/svg%3E');
                opacity: 0.6;
            }

        .process-item {
            position: relative;
            z-index: 1;
        }

        .process-img-wrapper {
            width: 180px;
            height: 180px;
            margin: 0 auto;
            border-radius: 50%;
            overflow: hidden;
            border: 8px solid white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.4s ease;
        }

            .process-img-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s ease;
            }

        .process-item:hover .process-img-wrapper {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 15px 40px rgba(46, 125, 50, 0.2);
            border-color: #c8e6c9;
        }

            .process-item:hover .process-img-wrapper img {
                transform: scale(1.1);
            }

        @@media (min-width: 992px) {
            .timeline-line {
                position: absolute;
                top: 90px;
                left: 10%;
                right: 10%;
                height: 2px;
                background-color: #c8e6c9;
                z-index: 0;
            }

            .timeline-dot {
                position: absolute;
                top: 83px;
                left: 50%;
                transform: translateX(-50%);
                width: 16px;
                height: 16px;
                background-color: var(--primary-green);
                border: 4px solid white;
                border-radius: 50%;
                z-index: 1;
                box-shadow: 0 0 0 4px #c8e6c9;
            }
        }

        /* 3. Product Card Styling */
        .product-card {
            border: 1px solid #f0f0f0;
            border-radius: 16px;
            background: #fff;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }

            .product-card:hover:not(.out-of-stock) {
                transform: translateY(-8px);
                box-shadow: 0 18px 35px rgba(0,0,0,0.06) !important;
                border-color: #d1e7dd;
            }

        .img-container {
            overflow: hidden;
            position: relative;
            height: 260px;
            border-radius: 16px 16px 0 0;
        }

            .img-container img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s ease;
            }

        .product-card:hover:not(.out-of-stock) .img-container img {
            transform: scale(1.08);
        }

        /* --- HIỆU ỨNG HẾT HÀNG ĐỒNG BỘ --- */
        .out-of-stock {
            opacity: 0.8;
        }

            .out-of-stock .img-container img {
                filter: grayscale(100%);
            }

        .out-of-stock-overlay {
            background: rgba(255, 255, 255, 0.6);
            z-index: 5;
        }

        .btn-cart-icon:disabled {
            background-color: #f1f3f5 !important;
            color: #adb5bd !important;
            cursor: not-allowed;
            box-shadow: none !important;
        }

            .btn-cart-icon:disabled:hover {
                transform: none !important;
            }
        /* -------------------------------- */

        .badge-hot {
            background: linear-gradient(45deg, #ff416c, #ff4b2b);
            padding: 6px 14px;
            font-size: 0.8rem;
            letter-spacing: 1px;
            z-index: 10;
        }

        .badge-new {
            background: linear-gradient(45deg, #00b09b, #96c93d);
            padding: 6px 14px;
            font-size: 0.8rem;
            letter-spacing: 1px;
            z-index: 10;
        }

        .product-title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            height: 48px;
            font-size: 1.1rem;
            line-height: 1.4;
        }

        .product-stats {
            padding: 8px 12px;
            margin-bottom: 15px;
            font-size: 0.85rem;
        }

        .product-price {
            color: var(--primary-green);
            font-size: 1.3rem;
        }

        .btn-cart-icon {
            background-color: var(--light-green);
            color: var(--primary-green);
            border: none;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .btn-cart-icon:hover:not(:disabled) {
                background-color: var(--primary-green);
                color: white;
            }

        /* 4. Utilities */
        .section-padding {
            padding: 80px 0;
        }

        .newsletter-section {
            background-color: var(--dark-green);
            background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.05"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');
        }
    </style>
}

<section class="hero-banner">
    <div class="hero-text animate__animated animate__fadeIn">
        <h1 class="animate__animated animate__zoomIn">LIFE AND TREES</h1>
        <p class="animate__animated animate__fadeInUp animate__delay-1s">
            Mang hơi thở thiên nhiên và sự bình yên vào không gian sống của bạn
        </p>
        <a href="#shop-now" class="btn btn-custom-primary btn-lg px-5 rounded-pill fw-bold shadow py-3 animate__animated animate__fadeInUp animate__delay-2s">
            MUA SẮM NGAY <i class="bi bi-arrow-right-short fs-5 align-middle"></i>
        </a>
    </div>
</section>

<section class="section-padding bg-white pb-3">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-md-4 feature-box">
                <div class="icon-wrapper">
                    <i class="bi bi-heart-pulse"></i>
                </div>
                <h5 class="fw-bold">Sống Khỏe Mạnh</h5>
                <p class="text-muted small mb-0">Cây xanh giúp lọc bụi mịn và cung cấp oxy trong lành cho ngôi nhà bạn.</p>
            </div>
            <div class="col-md-4 feature-box border-md-x">
                <div class="icon-wrapper">
                    <i class="bi bi-magic"></i>
                </div>
                <h5 class="fw-bold">Trang Trí Tinh Tế</h5>
                <p class="text-muted small mb-0">Đa dạng mẫu mã từ cây để bàn đến cây nội thất kích thước lớn.</p>
            </div>
            <div class="col-md-4 feature-box">
                <div class="icon-wrapper">
                    <i class="bi bi-truck"></i>
                </div>
                <h5 class="fw-bold">Giao Hàng Tận Tâm</h5>
                <p class="text-muted small mb-0">Đóng gói chuyên nghiệp, đảm bảo cây đến tay luôn tươi tốt.</p>
            </div>
        </div>
    </div>
</section>

<section class="section-padding bg-white">
    <div class="container care-process-section p-5 shadow-sm">
        <div class="text-center mb-5 position-relative z-1">
            <h2 class="fw-bold display-6 text-success">Hành trình nuôi dưỡng mầm xanh</h2>
            <p class="text-muted fs-6 mt-3 max-w-75 mx-auto">Chăm sóc cây trang trí không chỉ là tưới nước, đó là một nghệ thuật tận hưởng cuộc sống chậm và kết nối với thiên nhiên ngay tại nhà.</p>
            <div class="mx-auto rounded mt-3" style="height: 4px; width: 60px; background-color: var(--accent-orange);"></div>
        </div>

        <div class="row g-5 position-relative">
            <div class="timeline-line d-none d-lg-block"></div>

            <div class="col-md-6 col-lg-3 text-center process-item">
                <div class="d-none d-lg-block timeline-dot"></div>
                <div class="process-img-wrapper mb-4">
                    <img src="https://images.pexels.com/photos/7313045/pexels-photo-7313045.jpeg" alt="Chọn cây trang trí">
                </div>
                <div class="px-2 position-relative z-1">
                    <span class="badge bg-success rounded-pill mb-2 px-3 py-2">Bước 1</span>
                    <h5 class="fw-bold text-dark mb-2">Chọn "bạn đồng hành"</h5>
                    <p class="text-muted small mb-0">Tìm loại cây phù hợp với ánh sáng và không gian ngôi nhà, cũng như lịch trình bận rộn của bạn.</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3 text-center process-item">
                <div class="d-none d-lg-block timeline-dot"></div>
                <div class="process-img-wrapper mb-4">
                    <img src="https://images.pexels.com/photos/5997230/pexels-photo-5997230.jpeg" alt="Thay chậu cho cây">
                </div>
                <div class="px-2 position-relative z-1">
                    <span class="badge bg-success rounded-pill mb-2 px-3 py-2">Bước 2</span>
                    <h5 class="fw-bold text-dark mb-2">Thay "áo mới" sang chảnh</h5>
                    <p class="text-muted small mb-0">Sử dụng chậu có lỗ thoát nước và hỗn hợp đất tơi xốp, giàu dinh dưỡng để rễ cây phát triển khỏe mạnh.</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3 text-center process-item">
                <div class="d-none d-lg-block timeline-dot"></div>
                <div class="process-img-wrapper mb-4">
                    <img src="https://images.pexels.com/photos/7010476/pexels-photo-7010476.jpeg" alt="Tưới nước cho cây">
                </div>
                <div class="px-2 position-relative z-1">
                    <span class="badge bg-success rounded-pill mb-2 px-3 py-2">Bước 3</span>
                    <h5 class="fw-bold text-dark mb-2">Tưới nước đúng điệu</h5>
                    <p class="text-muted small mb-0">Kiểm tra độ ẩm của đất bằng tay trước khi tưới. Không tưới quá nhiều, hãy để đất "thở" giữa các lần tưới.</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3 text-center process-item">
                <div class="d-none d-lg-block timeline-dot"></div>
                <div class="process-img-wrapper mb-4">
                    <img src="https://images.pexels.com/photos/3932930/pexels-photo-3932930.jpeg" alt="Tận hưởng không gian xanh">
                </div>
                <div class="px-2 position-relative z-1">
                    <span class="badge bg-success rounded-pill mb-2 px-3 py-2">Bước 4</span>
                    <h5 class="fw-bold text-dark mb-2">Tận hưởng thành quả</h5>
                    <p class="text-muted small mb-0">Dành thời gian ngắm nhìn cây lớn lên mỗi ngày. Lau lá, tỉa cành và cảm nhận sự bình yên mà cây mang lại.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container section-padding pt-0" id="shop-now">

    @* SẢN PHẨM MỚI NHẤT *@
    <div class="text-center mb-5">
        <h2 class="fw-bold display-6">Sản phẩm mới nhất</h2>
        <p class="text-muted fs-6 mt-2 max-w-75 mx-auto">Khám phá những mầm xanh vừa cập bến Life and Trees, sẵn sàng làm bừng sáng và mang lại năng lượng tích cực cho không gian của bạn.</p>
        <div class="mx-auto rounded mt-3" style="height: 4px; width: 60px; background-color: var(--primary-green);"></div>
    </div>

    <div class="row g-4 mb-5 pb-4 border-bottom">
        @* SỬ DỤNG BIẾN newestProducts ĐÃ ĐƯỢC LỌC Ở TRÊN *@
        @foreach (var item in newestProducts)
        {
            bool isOutOfStock = item.Quantity <= 0;

            <div class="col-md-6 col-lg-3">

                <div class="card product-card h-100 shadow-sm @(isOutOfStock ? "out-of-stock" : "")" id="product-card-@item.ProductId">
                    <div class="img-container position-relative">
                        <span class="badge badge-new text-uppercase position-absolute top-0 start-0 m-3 shadow-sm rounded-pill">Mới</span>
                        <img src="@item.ImageUrl" alt="@item.ProductName" loading="lazy">

                        @* Overlay báo Hết Hàng *@
                        <div id="out-of-stock-badge-@item.ProductId" class="out-of-stock-overlay position-absolute top-0 start-0 w-100 h-100 justify-content-center align-items-center @(isOutOfStock ? "d-flex" : "d-none")">
                            <span class="badge bg-dark text-white fw-bold px-3 py-2 fs-6 shadow-sm" style="letter-spacing: 1px;">TẠM HẾT HÀNG</span>
                        </div>
                    </div>

                    <div class="card-body p-4 d-flex flex-column">
                        <span class="text-muted small text-uppercase mb-1 d-block" style="font-size: 0.75rem; letter-spacing: 1px;">
                            @item.Category?.CategoryName
                        </span>
                        <h5 class="card-title fw-bold text-dark mb-3 product-title">@item.ProductName</h5>

                        <div class="product-stats d-flex justify-content-between align-items-center text-muted">
                            <span><i class="bi bi-box-seam text-success"></i> Kho: <strong id="stock-@item.ProductId">@item.Quantity</strong></span>
                            <span><i class="bi bi-cart-check text-warning"></i> Đã bán: <strong>@(item.SoldQuantity)</strong></span>
                        </div>

                        <div class="mt-auto">
                            <p class="product-price fw-bold mb-3">@item.Price.ToString("N0") <span class="text-decoration-underline small fs-6">đ</span></p>

                            <div class="d-flex gap-2">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                   class="btn btn-outline-success rounded-pill flex-grow-1 fw-bold">
                                    Chi tiết
                                </a>
                                <button id="btn-add-cart-@item.ProductId" class="btn btn-cart-icon rounded-circle shadow-sm" style="width: 42px; height: 42px;" onclick="addToCart(@item.ProductId)" title="Thêm vào giỏ" @(isOutOfStock ? "disabled" : "")>
                                    <i class="bi bi-cart-plus fs-5"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* SẢN PHẨM BÁN CHẠY *@
    <div class="text-center mb-5 mt-4">
        <h2 class="fw-bold display-6">Sản phẩm bán chạy</h2>
        <p class="text-muted fs-6 mt-2 max-w-75 mx-auto">Những chậu cây được yêu thích và săn đón nhiều nhất, lựa chọn hoàn hảo để thanh lọc không khí và trang trí nhà cửa.</p>
        <div class="mx-auto rounded mt-3" style="height: 4px; width: 60px; background-color: var(--primary-green);"></div>
    </div>

    <div class="row g-4">
        @* SỬ DỤNG BIẾN bestSellingProducts ĐÃ ĐƯỢC LỌC Ở TRÊN *@
        @foreach (var item in bestSellingProducts)
        {
            bool isOutOfStock = item.Quantity <= 0;

            <div class="col-md-6 col-lg-3" >
                <div class="card product-card h-100 shadow-sm @(isOutOfStock ? "out-of-stock" : "")" id="product-card-@item.ProductId">
                    <div class="img-container position-relative">  
                        <span class="badge badge-hot text-uppercase position-absolute top-0 start-0 m-3 shadow-sm rounded-pill">Hot</span>
                        <img src="@item.ImageUrl" alt="@item.ProductName" loading="lazy">

                        @* Overlay báo Hết Hàng *@
                        <div id="out-of-stock-badge-@item.ProductId" class="out-of-stock-overlay position-absolute top-0 start-0 w-100 h-100 justify-content-center align-items-center @(isOutOfStock ? "d-flex" : "d-none")">
                            <span class="badge bg-dark text-white fw-bold px-3 py-2 fs-6 shadow-sm" style="letter-spacing: 1px;">TẠM HẾT HÀNG</span>
                        </div>
                    </div>

                    <div class="card-body p-4 d-flex flex-column">
                        <span class="text-muted small text-uppercase mb-1 d-block" style="font-size: 0.75rem; letter-spacing: 1px;">
                            @item.Category?.CategoryName
                        </span>
                        <h5 class="card-title fw-bold text-dark mb-3 product-title">@item.ProductName</h5>

                        <div class="product-stats d-flex justify-content-between align-items-center text-muted">
                            <span><i class="bi bi-box-seam text-success"></i> Kho: <strong id="stock-@item.ProductId">@item.Quantity</strong></span>
                            <span><i class="bi bi-cart-check text-warning"></i> Đã bán: <strong>@(item.SoldQuantity)</strong></span>
                        </div>

                        <div class="mt-auto">
                            <p class="product-price fw-bold mb-3">@item.Price.ToString("N0") <span class="text-decoration-underline small fs-6">đ</span></p>

                            <div class="d-flex gap-2">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                   class="btn btn-outline-success rounded-pill flex-grow-1 fw-bold">
                                    Chi tiết
                                </a>
                                <button id="btn-add-cart-@item.ProductId" class="btn btn-cart-icon rounded-circle shadow-sm" style="width: 42px; height: 42px;" onclick="addToCart(@item.ProductId)" title="Thêm vào giỏ" @(isOutOfStock ? "disabled" : "")>
                                    <i class="bi bi-cart-plus fs-5"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<section class="section-padding newsletter-section text-white rounded-top-5 mt-5 shadow-lg">
    <div class="container text-center">
        <i class="bi bi-envelope-paper fs-1 text-warning mb-3 d-block"></i>
        <h2 class="fw-bold mb-3">Nhận bí kíp chăm sóc cây</h2>
        <p class="mb-5 opacity-75 fs-5">Đăng ký email để nhận ngay cẩm nang và ưu đãi <span class="text-warning fw-bold">10%</span> cho đơn hàng đầu tiên.</p>
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="input-group input-group-lg shadow-sm">
                    <input type="email" class="form-control border-0 rounded-start-pill px-4 fs-6" placeholder="Nhập địa chỉ email của bạn...">
                    <button class="btn btn-warning text-dark rounded-end-pill px-4 fw-bold fs-6" type="button">ĐĂNG KÝ</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function addToCart(productId) {
            fetch('@Url.Action("AddToCart", "Cart")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'productId=' + productId + '&quantity=1'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // Cập nhật số trên icon giỏ hàng
                    const cartBadge = document.getElementById("cart-count");
                    if(cartBadge) {
                        cartBadge.innerText = data.count;
                        cartBadge.classList.add('animate__animated', 'animate__bounceIn');
                        setTimeout(() => cartBadge.classList.remove('animate__animated', 'animate__bounceIn'), 1000);
                    }

                    // Cập nhật số lượng kho NGAY TRÊN giao diện (NẾU HẾT THÌ LÀM MỜ LUÔN)
                    const stockElements = document.querySelectorAll(`#stock-${productId}`);
                    stockElements.forEach(stockElement => {
                        let currentStock = parseInt(stockElement.innerText);
                        if (currentStock > 0) {
                            let newStock = currentStock - 1;
                            stockElement.innerText = newStock;
                            stockElement.classList.add('animate__animated', 'animate__headShake', 'text-danger');
                            setTimeout(() => stockElement.classList.remove('animate__animated', 'animate__headShake', 'text-danger'), 1000);

                            // NẾU MUA XONG MÀ VỀ 0 -> CHUYỂN TRẠNG THÁI HẾT HÀNG
                            if(newStock === 0) {
                                // Tìm tất cả các thẻ của sản phẩm này (vì nó có thể xuất hiện ở cả Mới nhất & Bán chạy)
                                const cards = document.querySelectorAll(`#product-card-${productId}`);
                                cards.forEach(card => card.classList.add('out-of-stock'));

                                const buttons = document.querySelectorAll(`#btn-add-cart-${productId}`);
                                buttons.forEach(btn => btn.disabled = true);

                                const overlays = document.querySelectorAll(`#out-of-stock-badge-${productId}`);
                                overlays.forEach(overlay => {
                                    overlay.classList.remove('d-none');
                                    overlay.classList.add('d-flex');
                                });
                            }
                        }
                    });

                    Swal.fire({
                        icon: 'success',
                        title: 'Đã thêm vào giỏ!',
                        text: 'Sản phẩm đã nằm gọn trong giỏ hàng của bạn.',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 2000,
                        timerProgressBar: true,
                        background: '#e8f5e9',
                        color: '#2e7d32',
                        iconColor: '#2e7d32'
                    });
                }
            });
        }
    </script>
}