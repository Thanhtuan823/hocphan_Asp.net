@model IEnumerable<lab2.Models.Product>

<div class="container my-5">
    <h2 class="text-success mb-4 text-center">🌱 Life and Trees</h2>
    <div class="mb-4">
        <div class="position-relative">
            <img src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6"
                 class="w-100 rounded shadow"
                 style="height:300px; object-fit:cover;" />

            <div class="position-absolute top-50 start-50 translate-middle text-center text-white">
                <h2 class="fw-bold">🌿 Không gian xanh cho cuộc sống</h2>
                <p>Chọn ngay cho bạn một chậu cây yêu thích</p>
            </div>
        </div>
    </div>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success text-center">
            @ViewBag.SuccessMessage
        </div>
    }

    <div class="row">

        <!-- CATEGORY -->
        <div class="col-lg-3 mb-4">
            <div class="bg-light p-3 rounded shadow-sm">
                <h5 class="text-success">Danh mục sản phẩm</h5>
                @await Component.InvokeAsync("CategoryMenu")
            </div>
        </div>

        <!-- PRODUCT -->
        <div class="col-lg-9">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">

                            <!-- IMAGE -->
                            <img src="@item.ImageUrl"
                                 class="card-img-top"
                                 style="height:250px; object-fit:cover;"
                                 alt="@item.ProductName" />

                            <!-- BODY -->
                            <div class="card-body d-flex flex-column text-center">

                                <h5 class="text-success fw-bold">
                                    @item.ProductName
                                </h5>

                                <p class="text-success fw-bold">
                                    @item.Price.ToString("N0") đ
                                </p>

                                <p class="text-muted">
                                    @item.Category?.CategoryName
                                </p>

                                <!-- BUTTON -->
                                <div class="mt-auto d-flex gap-2">

                                    <!-- CHI TIẾT -->
                                    <a asp-controller="Product"
                                       asp-action="Details"
                                       asp-route-id="@item.ProductId"
                                       class="btn btn-outline-success btn-sm w-50">
                                        Chi tiết
                                    </a>

                                    <!-- ADD TO CART -->
                                    <button type="button"
                                            class="btn btn-success btn-sm w-50"
                                            onclick="addToCart(@item.ProductId)">
                                        <i class="bi bi-cart-plus"></i>
                                    </button>

                                </div>

                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>

    </div>
</div>

<!-- SCRIPT -->
<script>
    function addToCart(productId) {
        fetch('@Url.Action("AddToCart", "Cart")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: 'productId=' + productId + '&quantity=1'
        })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    document.getElementById("cart-count").innerText = data.count;
                } else {
                    alert("Thêm vào giỏ thất bại!");
                }
            })
            .catch(err => console.log(err));
    }
</script>
