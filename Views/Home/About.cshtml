@{
    ViewData["Title"] = "Về Chúng Tôi";
}

<div class="about-wrapper">
    <section class="about-hero text-center py-5 mb-5 rounded-5 shadow-sm overflow-hidden position-relative">
        <div class="hero-bg-image"></div>
        <div class="hero-overlay"></div>
        <div class="container position-relative z-3 py-5">
            <h6 class="text-uppercase fw-bold text-success tracking-widest mb-3 animate-up">🌿 Khởi nguồn từ tình yêu</h6>
            <h1 class="display-3 fw-bold text-dark mb-4 animate-up-delay-1">Life and Trees <br><span class="text-success italic">Hành trình xanh hóa</span></h1>
            <p class="lead text-dark mx-auto mb-0 fw-medium animate-up-delay-2" style="max-width: 700px;">
                Chúng tôi không chỉ bán cây, chúng tôi mang đến những "người bạn" giúp thanh lọc tâm hồn và làm mới không gian sống của bạn mỗi ngày.
            </p>
        </div>
    </section>

    <div class="container mb-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 order-2 order-lg-1">
                <div class="position-relative img-hover-container">
                    <img src="https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?q=80&w=1000"
                         alt="Our Garden" class="img-fluid rounded-5 shadow-lg main-img">

                    <div class="experience-badge bg-success text-white p-4 rounded-4 shadow-lg position-absolute bottom-0 start-0 m-4">
                        <h2 class="fw-bold mb-0">10+</h2>
                        <p class="small mb-0 text-uppercase fw-semibold">Năm kinh nghiệm</p>
                    </div>
                </div>
                <p class="text-muted mt-3 ms-2 small italic"><i class="bi bi-camera me-1"></i> Hình ảnh thực tế tại vườn ươm trung tâm của Life and Trees.</p>
            </div>
            <div class="col-lg-6 order-1 order-lg-2">
                <h2 class="fw-bold mb-4">Tại sao chọn <span class="text-success">Life and Trees?</span></h2>

                <div class="mission-item d-flex mb-4 p-3 rounded-4">
                    <div class="icon-box bg-success-subtle text-success rounded-4 p-3 me-3">
                        <i class="bi bi-heart-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Tâm huyết tuyển chọn</h5>
                        <p class="text-muted mb-0">Từng chiếc lá, gốc rễ đều được đội ngũ chuyên gia kiểm tra nghiêm ngặt trước khi nhập kho.</p>
                    </div>
                </div>

                <div class="mission-item d-flex mb-4 p-3 rounded-4">
                    <div class="icon-box bg-warning-subtle text-warning rounded-4 p-3 me-3">
                        <i class="bi bi-brightness-high-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Ánh sáng cho không gian</h5>
                        <p class="text-muted mb-0">Chúng tôi cung cấp giải pháp tư vấn hướng nắng, độ ẩm phù hợp cho từng căn hộ khác nhau.</p>
                    </div>
                </div>

                <div class="mission-item d-flex p-3 rounded-4">
                    <div class="icon-box bg-info-subtle text-info rounded-4 p-3 me-3">
                        <i class="bi bi-leaf-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold">Nông nghiệp hữu cơ</h5>
                        <p class="text-muted mb-0">Cam kết sử dụng phân bón và thuốc trừ sâu 100% sinh học, an toàn cho trẻ nhỏ và thú cưng.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Cảm hứng từ <span class="text-success">Khách hàng</span></h2>
            <p class="text-muted">Hình ảnh cây xanh được bài trí trong không gian sống hiện đại</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="gallery-card rounded-5 overflow-hidden shadow-sm">
                    <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=600" alt="Office Green" class="w-100">
                    <div class="gallery-overlay"><span>Văn phòng xanh</span></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="gallery-card rounded-5 overflow-hidden shadow-sm">
                    <img src="https://images.unsplash.com/photo-1483058712412-4245e9b90334?q=80&w=600" alt="Living Room" class="w-100">
                    <div class="gallery-overlay"><span>Phòng khách ấm cúng</span></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="gallery-card rounded-5 overflow-hidden shadow-sm">
                    <img src="https://images.unsplash.com/photo-1512428559087-560fa5ceab42?q=80&w=600" alt="Balcony" class="w-100">
                    <div class="gallery-overlay"><span>Ban công thư giãn</span></div>
                </div>
            </div>
        </div>
    </div>

    <section class="stats-section py-5 my-5 bg-dark rounded-5 text-white shadow-lg">
        <div class="container">
            <div class="row text-center g-4">
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bold text-success">5000+</h2>
                    <p class="text-white-50">Khách hàng tin tưởng</p>
                </div>
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bold text-success">120+</h2>
                    <p class="text-white-50">Loại cây hiếm</p>
                </div>
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bold text-success">24/7</h2>
                    <p class="text-white-50">Hỗ trợ chăm sóc</p>
                </div>
                <div class="col-md-3 col-6">
                    <h2 class="display-5 fw-bold text-success">100%</h2>
                    <p class="text-white-50">Tự nhiên hữu cơ</p>
                </div>
            </div>
        </div>
    </section>

    <div class="container text-center py-5 mb-5">
        <div class="cta-box p-5 rounded-5 bg-white shadow-sm border border-success-subtle position-relative overflow-hidden">
            <div class="cta-content position-relative z-3">
                <h3 class="fw-bold mb-3">Bạn đã sẵn sàng để trở thành một "Green-lover"?</h3>
                <p class="text-muted mb-4">Ghé thăm bộ sưu tập cây cảnh nội thất mới nhất của chúng tôi.</p>
                <a asp-controller="Product" asp-action="Index" class="btn btn-success btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg">Bắt đầu mua sắm ngay</a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Hiệu ứng mượt mà cho toàn trang */
        .about-wrapper {
            animation: fadeIn 1s ease-in;
        }

        /* Hero Section với ảnh nền ẩn dưới */
        .about-hero {
            min-height: 450px;
            display: flex;
            align-items: center;
            background: #fff;
        }

        .hero-bg-image {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('https://images.unsplash.com/photo-1470058869958-2a77a6777f51?q=80&w=1500');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            z-index: 1;
        }

        .hero-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, transparent 20%, #ffffff 80%);
            z-index: 2;
        }

        /* Gallery Cards */
        .gallery-card {
            position: relative;
            height: 300px;
        }

            .gallery-card img {
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s ease;
            }

        .gallery-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(25, 135, 84, 0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            opacity: 0;
            transition: 0.3s;
        }

        .gallery-card:hover img {
            transform: scale(1.1);
        }

        .gallery-card:hover .gallery-overlay {
            opacity: 1;
        }

        /* Các hiệu ứng nhỏ khác */
        .mission-item {
            transition: 0.3s;
        }

            .mission-item:hover {
                background-color: #f8fcf9;
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            }

        .tracking-widest {
            letter-spacing: 4px;
        }

        .italic {
            font-style: italic;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .animate-up {
            animation: fadeInUp 0.8s ease-out;
        }

        .animate-up-delay-1 {
            animation: fadeInUp 1s ease-out;
        }

        .animate-up-delay-2 {
            animation: fadeInUp 1.2s ease-out;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}