@model lab2.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký thành viên";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="card border-0 shadow-lg p-4 p-md-5 position-relative" style="width: 100%; max-width: 550px; border-radius: 25px;">

        <a asp-action="Auth" asp-controller="Account" class="btn-back text-success text-decoration-none" title="Quay lại">
            <i class="bi bi-arrow-left-circle-fill fs-3"></i>
        </a>

        <div class="text-center mb-4 mt-2">
            <div class="display-6 text-success mb-2">🌱</div>
            <h3 class="fw-bold text-success uppercase-tracking">THAM GIA CÙNG CHÚNG TÔI</h3>
            <p class="text-muted small">Khởi tạo tài khoản để chăm sóc vườn cây của riêng bạn</p>
        </div>

        <form asp-action="Register" method="post" class="px-lg-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="fw-semibold mb-1 text-secondary ms-2">Địa chỉ Email</label>
                <div class="input-group shadow-sm-custom">
                    <span class="input-group-text bg-light border-0 rounded-pill-start text-success px-3">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Email" class="form-control bg-light border-0 rounded-pill-end px-3 py-2" placeholder="email@vi-du.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small ms-2"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="fw-semibold mb-1 text-secondary ms-2">Mật khẩu</label>
                <div class="input-group shadow-sm-custom">
                    <span class="input-group-text bg-light border-0 rounded-pill-start text-success px-3">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input asp-for="Password" type="password" class="form-control bg-light border-0 rounded-pill-end px-3 py-2" placeholder="1234..." />
                </div>
                <span asp-validation-for="Password" class="text-danger small ms-2"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="ConfirmPassword" class="fw-semibold mb-1 text-secondary ms-2">Xác nhận mật khẩu</label>
                <div class="input-group shadow-sm-custom">
                    <span class="input-group-text bg-light border-0 rounded-pill-start text-success px-3">
                        <i class="bi bi-shield-check"></i>
                    </span>
                    <input asp-for="ConfirmPassword" type="password" class="form-control bg-light border-0 rounded-pill-end px-3 py-2" placeholder="1234..." />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small ms-2"></span>
            </div>

            <button type="submit" class="btn btn-success w-100 fw-bold rounded-pill py-3 shadow-sm mb-3 text-uppercase" style="letter-spacing: 1px;">
                ĐĂNG KÝ NGAY
            </button>
        </form>

        <div class="text-center mt-2">
            <p class="small text-muted mb-0">Bạn đã có tài khoản?</p>
            <a asp-action="Login" asp-controller="Account" class="text-success fw-bold text-decoration-none hover-underline">
                Quay lại Đăng nhập
            </a>
        </div>
    </div>
</div>

<style>
    .uppercase-tracking {
        letter-spacing: 1px;
    }

    /* Style cho nút Back */
    .btn-back {
        position: absolute;
        top: 25px;
        left: 25px;
        transition: all 0.3s ease;
        opacity: 0.6;
    }

        .btn-back:hover {
            transform: scale(1.1) translateX(-3px);
            opacity: 1;
            color: #157347 !important;
        }

    /* Bo tròn input group */
    .rounded-pill-start {
        border-radius: 50px 0 0 50px !important;
    }

    .rounded-pill-end {
        border-radius: 0 50px 50px 0 !important;
    }

    /* Shadow nhẹ cho các ô input để thêm chiều sâu */
    .shadow-sm-custom {
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.05);
        border-radius: 50px;
    }

    .hover-underline:hover {
        text-decoration: underline !important;
    }

    .form-control:focus {
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
        background-color: #fff !important;
        border: 1px solid #198754 !important;
    }
</style>