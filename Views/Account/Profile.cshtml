@model lab2.Models.UserProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<style>
    .profile-wrapper {
        background: #f4f7f6;
        min-height: 100vh;
    }

    .main-profile-card {
        border-radius: 25px;
        overflow: hidden;
        border: none;
        background: #fff;
    }

    .profile-sidebar {
        background: linear-gradient(180deg, #198754 0%, #0d4d30 100%);
    }

    .form-control-custom {
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
        padding: 12px 15px;
        border-radius: 12px;
        width: 100%;
        transition: all 0.3s;
    }

        .form-control-custom:focus {
            border-color: #198754;
            background-color: #fff;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
            outline: none;
        }

    .form-label-custom {
        font-weight: 600;
        color: #495057;
        margin-bottom: 5px;
    }

    .badge-custom {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        padding: 5px 12px;
        border-radius: 20px;
    }

    .info-box-sidebar {
        background: rgba(0,0,0,0.1);
        padding: 15px;
        border-radius: 15px;
    }

    .alert-soft-success {
        background-color: #d1e7dd;
        color: #0f5132;
        border: none;
        border-radius: 12px;
    }
</style>

<div class="profile-wrapper py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11 col-xl-10">
                <div class="main-profile-card shadow-lg animate__animated animate__zoomIn">

                    <form asp-action="UpdateFullProfile" method="post">

                        <div class="row g-0">

                            <div class="col-md-4 profile-sidebar text-white text-center p-5">
                                <div class="avatar-container mb-4">
                                    <img src="https://ui-avatars.com/api/?name=@Model.User.UserName&background=fff&color=198754&size=150"
                                         class="rounded-circle shadow-lg border border-4 border-white-50" alt="avatar">
                                    <div class="online-status"></div>
                                </div>
                                <h3 class="fw-bold mb-1">@Model.User.UserName</h3>
                                <div class="role-badges d-flex justify-content-center gap-2 flex-wrap mb-4">
                                    @foreach (var role in Model.User.Roles)
                                    {
                                        <span class="badge-custom small">@role</span>
                                    }
                                </div>

                                <div class="mt-4 text-start info-box-sidebar">
                                    <p class="small mb-2"><i class="bi bi-envelope me-2"></i> @Model.User.Email</p>
                                    <p class="small mb-0"><i class="bi bi-geo-alt me-2"></i> @(Model.OrderAddress?.City ?? "Chưa cập nhật")</p>
                                </div>
                            </div>

                            <div class="col-md-8 p-4 p-md-5 bg-white">
                                @if (TempData["SuccessMessage"] != null)
                                {
                                    <div class="alert alert-soft-success mb-4 animate__animated animate__fadeInDown">
                                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                                    </div>
                                }

                                <input type="hidden" asp-for="User.Id" />
                                <input type="hidden" asp-for="OrderAddress.UserId" />

                                <div class="section-title mb-4">
                                    <h5 class="fw-bold text-success"><i class="bi bi-person-badge me-2"></i>THÔNG TIN CÁ NHÂN</h5>
                                    <hr class="mt-2 opacity-10">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label-custom small">Nickname / Tên hiển thị</label>
                                    <input asp-for="User.UserName" class="form-control-custom" placeholder="Nhập tên của bạn...">
                                    <span asp-validation-for="User.UserName" class="text-danger small"></span>
                                </div>

                                <div class="section-title mb-4 mt-5">
                                    <h5 class="fw-bold text-success"><i class="bi bi-truck me-2"></i>ĐỊA CHỈ & SỐ ĐIỆN THOẠI GIAO HÀNG</h5>
                                    <hr class="mt-2 opacity-10">
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label-custom small">Họ tên người nhận</label>
                                        <input asp-for="OrderAddress.Name" class="form-control-custom" placeholder="Tên người nhận hàng">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label-custom small">Số điện thoại liên hệ</label>
                                        <input asp-for="OrderAddress.PhoneNumber" class="form-control-custom" placeholder="090...">
                                        <span asp-validation-for="OrderAddress.PhoneNumber" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label-custom small">Địa chỉ chi tiết (Số nhà, đường)</label>
                                    <input asp-for="OrderAddress.Address1" class="form-control-custom" placeholder="Ví dụ: 123 Đường ABC...">
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label-custom small">Thành phố / Tỉnh</label>
                                        <input asp-for="OrderAddress.City" class="form-control-custom" placeholder="Hà Nội, TP.HCM...">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label-custom small">Mã Zip</label>
                                        <input asp-for="OrderAddress.Zip" class="form-control-custom" placeholder="700000">
                                    </div>
                                </div>

                                <div class="d-flex gap-2 justify-content-end mt-5">
                                    <a asp-controller="Home" asp-action="Index" class="btn btn-light px-4 rounded-pill border">Hủy bỏ</a>
                                    <button type="submit" class="btn btn-success px-5 rounded-pill shadow-sm fw-bold">
                                        LƯU HỒ SƠ <i class="bi bi-check2-all ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                    <form id="profileForm" asp-action="UpdateFullProfile" method="post">
                    </form>

                    <div id="msgStatus" class="mt-3"></div>
                </div>
            </div>
        </div>
    </div>
</div>


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function () {
        $('#profileForm').on('submit', function (e) {
            e.preventDefault(); // Chặn việc load lại trang và hiện trang JSON

            var form = $(this);
            var actionUrl = form.attr('action');
            var formData = form.serialize();

            $.post(actionUrl, formData, function (response) {
                if (response.success) {
                    // Sử dụng SweetAlert2 để hiện thông báo cực đẹp
                    Swal.fire({
                        icon: 'success',
                        title: 'Thành công!',
                        text: response.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        // Tùy chọn: Load lại trang sau khi hiện thông báo để cập nhật giao diện
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi',
                        text: response.message
                    });
                }
            }).fail(function() {
                alert("Có lỗi xảy ra khi gửi dữ liệu!");
            });
        });
    });
</script>