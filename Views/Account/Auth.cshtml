@model dynamic
@{
    ViewData["Title"] = "Đăng nhập / Đăng ký";
}

<div class="container vh-100 d-flex justify-content-center align-items-center">
    <div class="row shadow-lg w-75">
        <!-- Cột Đăng ký -->
        <div class="col-md-6 bg-primary text-white d-flex flex-column justify-content-center p-5">
            <h3 class="mb-3">REGISTER</h3>
            <p>Don't have an account? Register one!</p>
            <form asp-action="Register" method="post">
                <button type="submit" class="btn btn-light w-100 fw-bold">REGISTER AN ACCOUNT</button>
            </form>
        </div>

        <!-- Cột Đăng nhập -->
        <div class="col-md-6 bg-white d-flex flex-column justify-content-center p-5">
            <h3 class="text-success mb-3">LOGIN</h3>
            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group mb-3">
                    <label>Username or email address *</label>
                    <input name="Email" class="form-control" />
                </div>
                <div class="form-group mb-3">
                    <label>Password *</label>
                    <input name="Password" type="password" class="form-control" />
                </div>
                <div class="form-check mb-3">
                    <input type="checkbox" class="form-check-input" id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">Remember me</label>
                </div>
                <button type="submit" class="btn btn-success w-100 fw-bold">LOG IN</button>
            </form>
            <div class="mt-3 text-center">
                <a href="#" class="text-decoration-none">Lost your password?</a>
            </div>
        </div>
    </div>
</div>