@model dynamic
@{
    ViewData["Title"] = "Đăng nhập / Đăng ký";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="row shadow-lg w-100 w-md-75 overflow-hidden position-relative" style="border-radius: 20px;">

        <a asp-controller="Home" asp-action="Index" class="btn-close-auth shadow-sm" title="Thoát">
            <i class="bi bi-x-lg"></i>
        </a>

        <div class="col-md-6 bg-success text-white d-flex flex-column justify-content-center p-5 text-center">
            <h3 class="fw-bold mb-3">CHƯA CÓ TÀI KHOẢN?</h3>
            <p class="mb-4">Đăng ký ngay để nhận ưu đãi và quản lý những chậu cây xinh xắn của riêng bạn!</p>
            <a asp-action="Register" class="btn btn-outline-light rounded-pill fw-bold px-4 py-2 hover-lift">
                ĐĂNG KÝ TÀI KHOẢN MỚI
            </a>
        </div>

        <div class="col-md-6 bg-white d-flex flex-column justify-content-center p-5">
            <div class="text-center mb-4">
                <h3 class="text-success fw-bold">ĐĂNG NHẬP</h3>
                <p class="text-muted small">Vui lòng nhập thông tin tài khoản của bạn</p>
            </div>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="form-group mb-3">
                    <label class="fw-semibold mb-1 text-secondary small">Email  *</label>
                    <input name="Email" class="form-control rounded-pill px-3 border-light bg-light" placeholder="example@gmail.com" required />
                </div>

                <div class="form-group mb-3">
                    <label class="fw-semibold mb-1 text-secondary small">Mật khẩu *</label>
                    <input name="Password" type="password" class="form-control rounded-pill px-3 border-light bg-light" placeholder="1234.." required />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe" />
                        <label class="form-check-label small text-muted" for="rememberMe">Ghi nhớ</label>
                    </div>
                    <a href="#" class="text-decoration-none small text-success fw-bold">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold rounded-pill py-2 shadow-sm btn-login-hover">
                    ĐĂNG NHẬP NGAY
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    /* Fix nút X: Chuyển sang màu xanh Success để nổi bật trên nền trắng */
    .btn-close-auth {
        position: absolute;
        top: 15px;
        right: 15px;
        width: 35px;
        height: 35px;
        background-color: #f8f9fa; /* Nền xám cực nhạt để tách biệt với màu trắng của card */
        color: #198754; /* Màu xanh lá để tiệp với tone web */
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        z-index: 10;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(25, 135, 84, 0.1); /* Viền mảnh màu xanh để rõ nét hơn */
    }

        .btn-close-auth i {
            font-size: 1rem;
            -webkit-text-stroke: 0.5px; /* Làm nét icon hơn */
        }

        .btn-close-auth:hover {
            background-color: #dc3545; /* Hover chuyển đỏ */
            color: white;
            transform: rotate(90deg);
            border-color: #dc3545;
            box-shadow: 0 4px 8px rgba(220, 53, 69, 0.3);
        }

    .hover-lift:hover {
        transform: translateY(-2px);
    }

    .btn-login-hover:hover {
        filter: brightness(1.1);
        transform: translateY(-1px);
    }
</style>