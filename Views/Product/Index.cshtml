@model IEnumerable<lab2.Models.Product>

<div class="container my-5">
    <!-- Tiêu đề căn giữa -->
    <h2 class="text-success mb-4 text-center">🌱 Life and Trees</h2>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success text-center">@ViewBag.SuccessMessage</div>
    }

    <div class="row">
        <!-- Category menu bên trái -->
        <div class="col-lg-3 mb-4">
            <div class="category-menu bg-light p-3 rounded shadow-sm d-inline-block">
                <h5 class="text-success">Danh mục sản phẩm</h5>
                @await Component.InvokeAsync("CategoryMenu")
            </div>
        </div>

        <!-- Danh sách sản phẩm bên phải -->
        <div class="col-lg-9">
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 w-150 shadow-sm">
                            <!-- Ảnh phủ hết chiều ngang card -->
                            <img src="@item.ImageUrl" class="card-img-top " alt="@item.ProductName"
                                 style="height:280px;object-fit:cover;" />
                            <div class="card-body d-flex flex-column align-items-center text-center">
                                <h5 class="card-title text-success fw-bold">@item.ProductName</h5>
                                <p class="card-text text-success fw-bold">@item.Price.ToString("N0") đ</p>
                                <p class="card-text text-muted">@item.Category?.CategoryName</p>

                                <!-- Nút bấm dàn ngang, căn giữa và không rớt chữ -->
                                <div class="mt-auto d-flex justify-content-center gap-3 w-100">
                                    @Html.ActionLink("Xem chi tiết", "Details", "Product",
                                    new { id = item.ProductId },
                                    new { @class = "btn btn-outline-success btn-sm flex-fill text-center text-nowrap" })
                                <button type="button" class="btn btn-success btn-sm flex-fill text-center text-nowrap"
                                        onclick="addToCart(@item.ProductId)">
                                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                                }
            </div>
        </div>
    </div>
</div>
<script>
     function addToCart(productId) {
        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'productId=' + productId + '&quantity=1'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById("cart-count").innerText = data.count;
            }
        });
    }
</script>